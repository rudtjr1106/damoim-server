# ── 집 PC 24/7 배포용 환경변수 예시 ──
# 이 파일을 복사해 `.env`로 쓰고 값을 채운다 (.env는 .gitignore로 커밋 제외).
#   cp .env.prod.example .env
# (외부 노출은 Tailscale Funnel이 담당 — 여기엔 터널 관련 값이 없다. DEPLOY.md 참고.)

# ── DB 비밀번호 (원하는 강한 값으로) ──
DB_PASSWORD=change-me-strong-db-password

# ── JWT 서명 키 (필수, 32바이트 이상 고정값) ──
# 절대 바꾸지 말 것 — 바뀌면 발급된 모든 로그인 토큰이 무효화된다.
# 새로 생성:  openssl rand -base64 48
JWT_SECRET=

# ── 카카오 앱 ID (필수, 0보다 커야 부팅됨) ──
# Kakao Developers → 내 애플리케이션 → 앱 설정 → 요약 정보 → "앱 ID"(숫자).
# (클라의 kakao.native.app.key와는 다른 값 — 서버가 카카오 토큰 검증에 쓰는 숫자 ID)
KAKAO_APP_ID=

# ── 파일 업로드(자료실)를 실제로 쓸 때만 (선택) ──
# 미설정이면 로컬 스텁이라 실제 파일 업로드는 안 된다. S3 연결 시:
# STORAGE_PROVIDER=s3
# S3_BUCKET=damoim-files
# S3_REGION=ap-northeast-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
