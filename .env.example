# 로컬 개발용 환경변수 예시.
# 이 파일을 복사해 `.env`로 쓰고 실제 값을 채운다 (.env는 .gitignore로 커밋 제외).
SPRING_PROFILES_ACTIVE=local
DB_URL=jdbc:postgresql://localhost:5432/damoim
DB_USERNAME=postgres
DB_PASSWORD=dev
SERVER_PORT=8080

# JWT 서명 키(로컬 미설정 시 임시 랜덤키 생성, 운영은 필수·32바이트+)
# JWT_SECRET=

# ── 파일 스토리지(자료실) ──
# 로컬 개발은 STORAGE_PROVIDER 미설정(=local 스텁, 실제 업로드 안 됨).
# 실제 S3 연결 시:
# STORAGE_PROVIDER=s3
# S3_BUCKET=damoim-files
# S3_REGION=ap-northeast-2
# AWS_ACCESS_KEY_ID=              # IAM 액세스 키 (운영은 IAM 역할 권장 — 키 불필요)
# AWS_SECRET_ACCESS_KEY=          # IAM 시크릿 (절대 커밋 금지)
# STORAGE_QUOTA_BYTES=5368709120  # 동아리당 5GB
# STORAGE_PRESIGN_EXPIRY=600      # presigned URL 만료(초)
